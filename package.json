{
  "name": "famoovie",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run build && wrangler pages dev",
    "dev:lan": "npm run build && wrangler pages dev --ip 0.0.0.0",
    "dev:vite": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "npm run build && wrangler pages deploy",
    "db:migrate:local": "wrangler d1 migrations apply famoovie --local",
    "db:migrate:remote": "wrangler d1 migrations apply famoovie --remote"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "vite": "^5.2.0",
    "wrangler": "^4.8.0"
  }
}
